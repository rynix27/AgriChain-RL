# ── AgriChain-RL Environment Variables ────────────────────────────────────────
# 1. Copy this file:   cp .env.example .env
# 2. Fill in your values.
# 3. NEVER commit .env — it is listed in .gitignore.
# ──────────────────────────────────────────────────────────────────────────────

# ── Twilio / WhatsApp Alerts ──────────────────────────────────────────────────
# Get these from https://console.twilio.com
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token_here

# Sandbox number (Twilio WhatsApp sandbox default — change for production)
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# Farmer's WhatsApp number to receive alerts
TWILIO_WHATSAPP_TO=whatsapp:+91XXXXXXXXXX

# Set to "true" to send real WhatsApp messages via Twilio.
# Leave as "false" (default) to simulate locally — no messages sent, no cost.
WHATSAPP_LIVE_MODE=false

# ── Hugging Face ──────────────────────────────────────────────────────────────
# Token for pushing trained model to Hub: https://huggingface.co/settings/tokens
HF_TOKEN=hf_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
HF_USERNAME=your-hf-username

# ── Weights & Biases (optional) ───────────────────────────────────────────────
WANDB_API_KEY=your_wandb_key_here
WANDB_PROJECT=agrichain-rl

# ── Server ────────────────────────────────────────────────────────────────────
PORT=7860
HOST=0.0.0.0
